# --- Database ---
# Local MongoDB (or use the bundled docker compose: `docker compose up -d mongo`)
DATABASE_URI=mongodb://127.0.0.1:27017/distribution-tracker

# --- Payload ---
# Secret used to sign auth tokens. Generate a unique one for every environment:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=YOUR_SECRET_HERE
